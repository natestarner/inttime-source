{
  // Java
  "java.configuration.updateBuildConfiguration": "automatic",
  "java.compile.nullAnalysis.mode": "automatic",
  "spring-boot.ls.java.home": null,

  // Spring Boot — use the local profile when running from VS Code
  "spring-boot.ls.javahome": null,

  // Editor defaults
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.tabSize": 2,
  "editor.insertSpaces": true,

  // Java files use the Java formatter, not Prettier
  "[java]": {
    "editor.defaultFormatter": "redhat.java",
    "editor.tabSize": 4
  },

  // YAML files
  "[yaml]": {
    "editor.defaultFormatter": "redhat.vscode-yaml",
    "editor.tabSize": 2
  },

  // Hide noisy directories from the file explorer
  "files.exclude": {
    "**/node_modules": true,
    "**/target": true,
    "**/.git": true,
    "**/build": true,
    "**/.settings": true,
    "**/.classpath": true,
    "**/.project": true,
    "**/.factorypath": true
  },

  // Search — skip generated/dependency directories
  "search.exclude": {
    "**/node_modules": true,
    "**/target": true,
    "**/build": true,
    "**/playwright-report": true
  },

  // TypeScript/JavaScript (for React + Playwright)
  "js/ts.preferences.importModuleSpecifier": "relative",

  // ESLint — auto-fix on save
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit"
  },

  // Terminal default directory
  "terminal.integrated.cwd": "${workspaceFolder}",

  // Default terminal profile — use Git Bash on Windows so all
  // bash commands in the guide work without modification
  "terminal.integrated.defaultProfile.windows": "Git Bash",

  // Playwright
  "playwright.reuseBrowser": true,

  // SQL Server connection (for the mssql extension)
  "mssql.connections": [
    {
      "server": "localhost,1433",
      "database": "inttime",
      "authenticationType": "SqlLogin",
      "user": "sa",
      "password": "",
      "savePassword": false,
      "profileName": "Local Dev DB"
    }
  ]
}